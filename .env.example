# Rasaoi — local frontend (Vite)
# Copy to .env and fill with YOUR personal Supabase project (see MIGRATE_SYNC_README.md)

VITE_SUPABASE_URL=https://YOUR_PERSONAL_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_public_key
VITE_SUPABASE_PROJECT_ID=YOUR_PERSONAL_REF

# Optional: force client-side mock fixtures (billing-free, no Google API)
# VITE_USE_MOCK_PLACES=true

# Optional: only if calling Google Places directly from the browser (not typical)
# VITE_GOOGLE_PLACES_API_KEY=

# Edge function secrets are NOT stored here. Set on Supabase via CLI:
#   npx supabase secrets set GEMINI_API_KEY=...
#   npx supabase secrets set FIRECRAWL_API_KEY=...
# GOOGLE_PLACES_API_KEY is OPTIONAL — omit for mock fixtures (no billing)
